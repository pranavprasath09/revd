# Copy this file to .env and fill in the values. Do not commit .env.
# Everything here is a client-side (VITE_) variable — only put values that
# are safe to expose in the browser. Server secrets (Stripe secret key,
# service role key, webhook signing secret) live in Supabase Edge Function
# secrets, never here.

# Supabase — project URL and public anon key
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Stripe — publishable key (client) and the premium plan's price ID
VITE_STRIPE_PUBLISHABLE_KEY=
VITE_STRIPE_PRICE_ID=
